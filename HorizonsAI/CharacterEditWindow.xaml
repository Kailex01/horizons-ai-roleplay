<Window x:Class="HorizonsAI.CharacterEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Character"
        Width="520" Height="720"
        MinWidth="460" MinHeight="560"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F1923"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="5" CaptionHeight="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#7A8B9A"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Width="38" Height="32">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5C1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A6070"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#111E2A"/>
            <Setter Property="Foreground"      Value="#D4C5A0"/>
            <Setter Property="BorderBrush"     Value="#1E3A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#C8A020"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="#8B6000"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A87800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1E3A50"/>
        </Style>
        <Style x:Key="DeleteBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#5C1A1A"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#080E14" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock x:Name="TitleText" Text="ADD CHARACTER"
                       Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="14,0"/>
            <Button Content="✕" Style="{StaticResource TitleBtn}"
                    HorizontalAlignment="Right" Click="Cancel_Click"/>
        </Grid>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12,20,0">
            <StackPanel>

                <!-- Portrait + Name row -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Portrait preview -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="36"
                                Background="#1E3A50" ClipToBounds="True"
                                Cursor="Hand" MouseLeftButtonDown="Portrait_Click"
                                ToolTip="Click to change portrait">
                            <Image x:Name="PortraitPreview" Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Text="portrait" Foreground="#4A6070" FontSize="9"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Name + Category -->
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="NAME" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>

                        <TextBlock Text="CATEGORY" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CategoryBox"
                                  IsEditable="True"
                                  Background="#111E2A" Foreground="#D4C5A0"
                                  BorderBrush="#1E3A50" BorderThickness="1"
                                  FontSize="12" Padding="6,5">
                            <ComboBoxItem Content="companions"/>
                            <ComboBoxItem Content="npcs"/>
                            <ComboBoxItem Content="player_characters"/>
                            <ComboBoxItem Content="intelligent_items"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- System Prompt -->
                <TextBlock Text="SYSTEM PROMPT" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="PromptBox"
                         Style="{StaticResource FieldBox}"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Height="120" VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,14"/>

                <!-- LLM Model -->
                <TextBlock Text="LLM MODEL (leave blank for default)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ModelBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <!-- Voice Profile -->
                <TextBlock Text="VOICE PROFILE" Style="{StaticResource FieldLabel}"/>
                <Border Background="#080E14" CornerRadius="4"
                        BorderBrush="#1E3A50" BorderThickness="1"
                        Padding="10,8" Margin="0,0,0,14">
                    <StackPanel>

                        <!-- Column headers -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Voice" Foreground="#4A6070" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Weight" Foreground="#4A6070" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Voice rows injected by code-behind -->
                        <StackPanel x:Name="VoiceEntriesPanel"/>

                        <!-- Add voice button -->
                        <Button x:Name="AddVoiceBtn" Content="+ Add voice"
                                HorizontalAlignment="Left" Margin="0,6,0,12"
                                Padding="8,4" FontSize="11" Cursor="Hand"
                                Background="Transparent" Foreground="#4A8AB0"
                                BorderBrush="#1E3A50" BorderThickness="1"
                                Click="AddVoice_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#0A1820"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Foreground" Value="#2A4A5A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Numeric parameters -->
                        <Border BorderBrush="#1E3A50" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="SPEED (0.5–2.0)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="SpeedBox"  Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBlock Text="PITCH SEMITONES (−12 to +12)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="PitchBox"  Style="{StaticResource FieldBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="TEMPO (0.5–2.0)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TempoBox"  Style="{StaticResource FieldBox}" Margin="0,0,0,10"/>
                                    <TextBlock Text="VOLUME (0.0–2.0)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="VolumeBox" Style="{StaticResource FieldBox}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Ability Scores -->
                <TextBlock Text="ABILITY SCORES" Style="{StaticResource FieldLabel}" Margin="0,4,0,3"/>
                <Border Background="#080E14" CornerRadius="4"
                        BorderBrush="#1E3A50" BorderThickness="1"
                        Padding="10,8" Margin="0,0,0,14">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="STR" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="StrBox" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DEX" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DexBox" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="CON" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ConBox" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="INT" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="IntBox" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="WIS" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="WisBox" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="CHA" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ChaBox" Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Enabled -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="EnabledBox" IsChecked="True"
                              Foreground="#D4C5A0" FontSize="12"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Enabled" Foreground="#D4C5A0" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#080E14" BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button x:Name="DeleteBtn" Content="Delete"
                        Style="{StaticResource DeleteBtn}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Visibility="Collapsed" Click="Delete_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Cancel" Style="{StaticResource CancelBtn}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="Save" Style="{StaticResource ActionBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
