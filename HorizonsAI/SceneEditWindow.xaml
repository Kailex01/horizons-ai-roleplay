<Window x:Class="HorizonsAI.SceneEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Scene"
        Width="480" Height="400"
        MinWidth="400" MinHeight="340"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F1923"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="5" CaptionHeight="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#7A8B9A"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Width="38" Height="32">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5C1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A6070"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#111E2A"/>
            <Setter Property="Foreground"      Value="#D4C5A0"/>
            <Setter Property="BorderBrush"     Value="#1E3A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#C8A020"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="#8B6000"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A87800"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1E3A50"/>
        </Style>
        <Style x:Key="DeleteBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#5C1A1A"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="#080E14" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock x:Name="TitleText" Text="ADD SCENE"
                       Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="14,0"/>
            <Button Content="✕" Style="{StaticResource TitleBtn}"
                    HorizontalAlignment="Right" Click="Cancel_Click"/>
        </Grid>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="20,14,20,0">

            <TextBlock Text="SCENE NAME" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

            <TextBlock Text="WORLD / SETTING CONTEXT" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="Describe the setting, lore, and atmosphere. The narrator and NPCs use this as their world context."
                       Foreground="#2A4A5A" FontSize="10" Margin="0,0,0,4" TextWrapping="Wrap"/>
            <TextBox x:Name="ContextBox"
                     Style="{StaticResource FieldBox}"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Height="160" VerticalScrollBarVisibility="Auto"/>

        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="2" Background="#080E14" BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Button x:Name="DeleteBtn" Content="Delete"
                        Style="{StaticResource DeleteBtn}"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Visibility="Collapsed" Click="Delete_Click"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Cancel" Style="{StaticResource CancelBtn}"
                            Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button Content="Save" Style="{StaticResource ActionBtn}"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
