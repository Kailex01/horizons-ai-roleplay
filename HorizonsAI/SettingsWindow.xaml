<Window x:Class="HorizonsAI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        Width="520" Height="560"
        MinWidth="440" MinHeight="480"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F1923"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="5" CaptionHeight="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#7A8B9A"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Width="38" Height="32">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5C1A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A6070"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#111E2A"/>
            <Setter Property="Foreground"      Value="#D4C5A0"/>
            <Setter Property="BorderBrush"     Value="#1E3A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#C8A020"/>
        </Style>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E3A50"/>
            <Setter Property="Foreground"      Value="#D4C5A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A4E6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SaveBtn" TargetType="Button" BasedOn="{StaticResource BrowseBtn}">
            <Setter Property="Background"  Value="#8B6000"/>
            <Setter Property="FontWeight"  Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#080E14" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock Text="SETTINGS" Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="14,0"/>
            <Button Content="✕" Style="{StaticResource TitleBtn}"
                    HorizontalAlignment="Right" Click="Cancel_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <StackPanel>
                <TextBlock Text="OPENROUTER API KEY" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="ApiKeyBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <TextBlock Text="DEFAULT LLM MODEL" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="DefaultModelBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <TextBlock Text="YOUR NAME (how you appear to characters)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="SpeakerNameBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <TextBlock Text="MAX REPLY TOKENS  (limits NPC/character response length — 60 = short, 150 = medium, 400 = long)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="MaxReplyTokensBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <TextBlock Text="NARRATOR VOICE  (used for GM narration and *action text* — leave blank to use character voice)"
                           Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                <!-- Voice dropdown -->
                <ComboBox x:Name="NarratorVoiceBox"
                          IsEditable="True" IsTextSearchEnabled="True"
                          Background="#111E2A" Foreground="#D4C5A0"
                          BorderBrush="#1E3A50" BorderThickness="1"
                          FontSize="12" Padding="6,5"
                          ToolTip="Pick or type a voice name"
                          Margin="0,0,0,6"/>
                <!-- Speed / Pitch / Volume sliders -->
                <Grid Margin="0,0,0,2">
                    <TextBlock Text="SPEED" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="NarratorSpeedLabel" Foreground="#C8A020" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="NarratorSpeedSlider" Style="{StaticResource DarkSlider}"
                        Minimum="0.5" Maximum="2.0" Value="1.0"
                        SmallChange="0.05" TickFrequency="0.05"
                        Margin="0,0,0,8" ValueChanged="OnNarratorSliderChanged"/>

                <Grid Margin="0,0,0,2">
                    <TextBlock Text="PITCH  (semitones  −12 to +12)" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="NarratorPitchLabel" Foreground="#C8A020" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="NarratorPitchSlider" Style="{StaticResource DarkSlider}"
                        Minimum="-12" Maximum="12" Value="0"
                        SmallChange="0.5" TickFrequency="0.5"
                        Margin="0,0,0,8" ValueChanged="OnNarratorSliderChanged"/>

                <Grid Margin="0,0,0,2">
                    <TextBlock Text="VOLUME" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="NarratorVolumeLabel" Foreground="#C8A020" FontSize="10"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="NarratorVolumeSlider" Style="{StaticResource DarkSlider}"
                        Minimum="0.0" Maximum="2.0" Value="1.0"
                        SmallChange="0.05" TickFrequency="0.05"
                        Margin="0,0,0,6" ValueChanged="OnNarratorSliderChanged"/>

                <!-- Default character prompt section -->
                <Border Height="1" Background="#1E3A50" Margin="0,10,0,10"/>

                <TextBlock Text="DEFAULT CHARACTER PROMPT" Foreground="#C8A020"
                           FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Foreground="#4A6070" FontSize="10" Margin="0,0,0,8">
                    Prepended to every character and NPC system prompt. Use this for world lore,
                    tone, and universal roleplay rules so you don't repeat them in every character.
                    Leave blank to disable.
                </TextBlock>
                <TextBox x:Name="DefaultCharacterPromptBox" Style="{StaticResource FieldBox}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinLines="5" MaxLines="10"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,14"/>

                <!-- Narrator / GM section -->
                <Border Height="1" Background="#1E3A50" Margin="0,10,0,10"/>

                <TextBlock Text="NARRATOR / GM" Foreground="#C8A020"
                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>

                <CheckBox x:Name="NarratorEnabledBox" Foreground="#D4C5A0" FontSize="12"
                          Content="Enable Narrator GM (evaluates scene after each NPC response)"
                          Margin="0,0,0,12"/>

                <TextBlock Text="NARRATOR MODEL  (blank = use default model above)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NarratorModelBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <TextBlock Text="GM SYSTEM PROMPT" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NarratorPromptBox" Style="{StaticResource FieldBox}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinLines="5" MaxLines="10"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,14"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#080E14" BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,16,0">
                <Button Content="Cancel" Style="{StaticResource BrowseBtn}"
                        Margin="0,0,8,0" Padding="16,7" Click="Cancel_Click"/>
                <Button Content="Save" Style="{StaticResource SaveBtn}"
                        Padding="24,7" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
