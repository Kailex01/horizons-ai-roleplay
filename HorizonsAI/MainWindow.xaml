<Window x:Class="HorizonsAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:conv="clr-namespace:HorizonsAI.Converters"
        Title="Horizon's AI"
        Width="1000" Height="680"
        MinWidth="750" MinHeight="500"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F1923"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="5" CaptionHeight="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:FirstLetterConverter x:Key="FirstLetter"/>

        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#7A8B9A"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Width="38" Height="32">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2D3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5C1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="#8B6000"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" FontSize="14"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#A87800"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A2A00"/>
                                <Setter Property="Foreground" Value="#6A5A30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VoiceToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background"      Value="#0A1018"/>
            <Setter Property="BorderBrush"     Value="#1E3A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1A3A2A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2A8040"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category expander header button -->
        <Style x:Key="CategoryHeader" TargetType="Button">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="HorizontalAlignment"  Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"               Value="Hand"/>
            <Setter Property="Padding"              Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared sidebar-row button template (used for both chars and parties) -->
        <ControlTemplate x:Key="SidebarRowTemplate" TargetType="Button">
            <Border x:Name="Bd" Padding="10,7"
                    BorderThickness="3,0,0,0"
                    BorderBrush="Transparent">
                <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Character row button -->
        <Style x:Key="CharRowBtn" TargetType="Button">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="HorizontalAlignment"  Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"               Value="Hand"/>
            <Setter Property="Padding"              Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="10,7"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="18"
                                        Background="#1E3A50" ClipToBounds="True"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="{Binding Portrait}" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#D4C5A0" FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding CategoryBadge}"
                                               Foreground="#4A6070" FontSize="9"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1A2E40"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C8A020"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Party row button -->
        <Style x:Key="PartyRowBtn" TargetType="Button">
            <Setter Property="Background"           Value="Transparent"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="HorizontalAlignment"  Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"               Value="Hand"/>
            <Setter Property="Padding"              Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="10,7"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- First-member portrait or placeholder -->
                                <Border Width="36" Height="36" CornerRadius="18"
                                        Background="#2A1E40" ClipToBounds="True"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid>
                                        <TextBlock Text="⚔" FontSize="16" Foreground="#6A4A8A"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Stretch="UniformToFill">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Members.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Source" Value="{Binding Members[0].Portrait}"/>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="#D4C5A0" FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding MemberCountText}"
                                               Foreground="#6A4A8A" FontSize="9"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#1A1A30"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8A60C8"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar add (+) button -->
        <Style x:Key="SidebarAddBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1E3A50"/>
            <Setter Property="Foreground"      Value="#C8A020"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="24"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A4E6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick-insert chip button base (template only; color via child styles) -->
        <Style x:Key="QuickBtn" TargetType="Button">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="9"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"          Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Attack chip: gold -->
        <Style x:Key="QuickBtnAtk" TargetType="Button" BasedOn="{StaticResource QuickBtn}">
            <Setter Property="Background"  Value="#2A1800"/>
            <Setter Property="Foreground"  Value="#C8A020"/>
            <Setter Property="BorderBrush" Value="#4A3010"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A3010"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- Check chip: blue -->
        <Style x:Key="QuickBtnChk" TargetType="Button" BasedOn="{StaticResource QuickBtn}">
            <Setter Property="Background"  Value="#0A1E30"/>
            <Setter Property="Foreground"  Value="#4A8AB0"/>
            <Setter Property="BorderBrush" Value="#1A3A50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A3A50"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Title bar ═══ -->
        <Grid Grid.Row="0" Background="#080E14" MouseLeftButtonDown="TitleBar_Drag">
            <TextBlock Text="HORIZON'S AI"
                       Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="14,0"/>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📖" Style="{StaticResource TitleBtn}" Click="Lorebook_Click"   ToolTip="Lorebook"/>
                <Button Content="⚙"  Style="{StaticResource TitleBtn}" Click="Settings_Click"  ToolTip="Settings"/>
                <Button Content="↺"  Style="{StaticResource TitleBtn}"
                        Command="{Binding ReloadTtsCommand}" ToolTip="Reload TTS voices"/>
                <Button Content="─"  Style="{StaticResource TitleBtn}" Click="Minimize_Click"  ToolTip="Minimize"/>
                <Button Content="⬜" Style="{StaticResource TitleBtn}" Click="MaxRestore_Click" ToolTip="Maximize"/>
                <Button Content="✕"  Style="{StaticResource CloseTitleBtn}" Click="Close_Click" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Main content ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="4" Background="#1E3A50"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

            <!-- ─── Sidebar ─── -->
            <Grid Grid.Column="0" Background="#0A1018">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>       <!-- Characters header -->
                    <RowDefinition Height="*"/>        <!-- Character list -->
                    <RowDefinition Height="44"/>       <!-- Parties header -->
                    <RowDefinition Height="Auto" MaxHeight="180"/> <!-- Party list -->
                    <RowDefinition Height="44"/>       <!-- Scenes header -->
                    <RowDefinition Height="Auto" MaxHeight="180"/> <!-- Scene list -->
                </Grid.RowDefinitions>

                <!-- Characters header -->
                <Border Grid.Row="0" Background="#080E14"
                        BorderBrush="#1E3A50" BorderThickness="0,0,0,1">
                    <Grid Margin="14,0,8,0">
                        <TextBlock Text="CHARACTERS" Foreground="#C8A020"
                                   FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="+" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource SidebarAddBtn}"
                                Click="AddCharacter_Click" ToolTip="Add Character"/>
                    </Grid>
                </Border>

                <!-- Category groups -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Category header -->
                                    <Button Style="{StaticResource CategoryHeader}"
                                            Click="CategoryHeader_Click" Tag="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#4A6070" FontSize="9" FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Foreground="#4A6070" FontSize="9"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▼"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Text" Value="▶"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Button>

                                    <!-- Character list -->
                                    <ItemsControl ItemsSource="{Binding Characters}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource CharRowBtn}"
                                                        Command="{Binding DataContext.SelectCharacterCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                              RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="Edit"   Click="EditCharacter_Click"/>
                                                            <MenuItem Header="Delete" Click="DeleteCharacter_Click"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Parties header -->
                <Border Grid.Row="2" Background="#080E14"
                        BorderBrush="#1E3A50" BorderThickness="0,1,0,1">
                    <Grid Margin="14,0,8,0">
                        <TextBlock Text="PARTIES" Foreground="#8A60C8"
                                   FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="+" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource SidebarAddBtn}"
                                Click="AddParty_Click" ToolTip="Add Party"/>
                    </Grid>
                </Border>

                <!-- Party list -->
                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Parties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource PartyRowBtn}"
                                        Command="{Binding DataContext.SelectPartyCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                              RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Edit"   Click="EditParty_Click"/>
                                            <MenuItem Header="Delete" Click="DeleteParty_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Scenes header -->
                <Border Grid.Row="4" Background="#080E14"
                        BorderBrush="#1E3A50" BorderThickness="0,1,0,1">
                    <Grid Margin="14,0,8,0">
                        <TextBlock Text="SCENES" Foreground="#20A870"
                                   FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="+" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource SidebarAddBtn}"
                                Click="AddScene_Click" ToolTip="Add Scene"/>
                    </Grid>
                </Border>

                <!-- Scene list -->
                <ScrollViewer Grid.Row="5"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Scenes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource PartyRowBtn}"
                                        Command="{Binding DataContext.SelectSceneCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                              RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Edit"   Click="EditScene_Click"/>
                                            <MenuItem Header="Delete" Click="DeleteScene_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ─── Chat area ─── -->
            <Grid Grid.Column="2" Background="#0F1923">
                <Grid.RowDefinitions>
                    <RowDefinition Height="68"/>    <!-- 0: header -->
                    <RowDefinition Height="*"/>     <!-- 1: messages -->
                    <RowDefinition Height="Auto"/>  <!-- 2: regenerate button -->
                    <RowDefinition Height="Auto"/>  <!-- 3: status text -->
                    <RowDefinition Height="Auto"/>  <!-- 4: author's note panel -->
                    <RowDefinition Height="Auto"/>  <!-- 5: quick action buttons -->
                    <RowDefinition Height="Auto"/>  <!-- 6: input bar -->
                </Grid.RowDefinitions>

                <!-- Character header (single character mode) -->
                <Border Grid.Row="0" Background="#0A1018"
                        BorderBrush="#1E3A50" BorderThickness="0,0,0,1"
                        Visibility="{Binding IsPartyActive, Converter={StaticResource InvBoolToVis}}">
                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="#1E3A50" ClipToBounds="True" VerticalAlignment="Center">
                            <Image Source="{Binding ActivePortrait}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveCharacterName}"
                                       Foreground="#D4C5A0" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ActiveCategoryBadge}"
                                       Foreground="#4A6070" FontSize="9"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Party header (party mode) -->
                <Border Grid.Row="0" Background="#0A1018"
                        BorderBrush="#1E3A50" BorderThickness="0,0,0,1"
                        Visibility="{Binding IsPartyActive, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveCharacterName}"
                                       Foreground="#D4C5A0" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="PARTY" Foreground="#8A60C8" FontSize="9"/>
                        </StackPanel>
                        <!-- Member portrait stack -->
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding ActivePartyMembers}"
                                      VerticalAlignment="Center" Margin="0,0,4,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="36" Height="36" CornerRadius="18"
                                            Background="#1E3A50" ClipToBounds="True"
                                            Margin="-8,0,0,0" VerticalAlignment="Center">
                                        <Image Source="{Binding Portrait}" Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Messages + Scene Roster -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12,8,12,4">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <!-- Memory summary marker -->
                                    <Border HorizontalAlignment="Stretch"
                                            Visibility="{Binding IsSummary, Converter={StaticResource BoolToVis}}">
                                        <StackPanel>
                                            <Border Background="#080E14" CornerRadius="4"
                                                    HorizontalAlignment="Center" Padding="14,5"
                                                    ToolTip="{Binding Text}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📚" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Earlier conversation condensed into memory"
                                                               Foreground="#4A6070" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <!-- Player bubble -->
                                    <Grid HorizontalAlignment="Right" MaxWidth="560"
                                          Visibility="{Binding IsPlayer, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#1A3A2A" CornerRadius="12,12,0,12" Padding="12,8">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                           RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="✏ Edit" Click="EditMessage_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SenderName}"
                                                           Foreground="#6AAA78" FontSize="10" FontWeight="Bold"
                                                           HorizontalAlignment="Right" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding Text}" Foreground="#A8D8B0"
                                                           FontSize="13" TextWrapping="Wrap"
                                                           Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Text="{Binding EditDraft, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#0F2A1A" BorderBrush="#2A6A3A" BorderThickness="1"
                                                         Foreground="#A8D8B0" FontSize="13" TextWrapping="Wrap"
                                                         CaretBrush="#C8A020" AcceptsReturn="True" MinLines="2"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                            Margin="0,4,0,0"
                                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                                    <Button Content="Save" Height="24" Padding="12,0" Margin="0,0,6,0"
                                                            FontSize="11" Background="#1A5A2A" Foreground="White"
                                                            BorderThickness="0" Cursor="Hand"
                                                            Command="{Binding DataContext.EditCommitCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Cancel" Height="24" Padding="12,0"
                                                            FontSize="11" Background="#3A1A1A" Foreground="#AAA"
                                                            BorderThickness="0" Cursor="Hand"
                                                            Command="{Binding DataContext.EditCancelCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding TimeStr}" Foreground="#4A6070"
                                                           FontSize="9" HorizontalAlignment="Right" Margin="0,4,0,0"
                                                           Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18"
                                                Background="#1E3A50" ClipToBounds="True"
                                                VerticalAlignment="Top" Margin="8,2,0,0"
                                                Visibility="{Binding HasPortrait, Converter={StaticResource BoolToVis}}">
                                            <Image Source="{Binding Portrait}" Stretch="UniformToFill"/>
                                        </Border>
                                    </Grid>
                                    <!-- Narrator action line -->
                                    <TextBlock
                                        Visibility="{Binding IsNarratorAction, Converter={StaticResource BoolToVis}}"
                                        Text="{Binding Text}"
                                        HorizontalAlignment="Center" TextAlignment="Center"
                                        FontStyle="Italic" Foreground="#C8A020"
                                        FontSize="13" TextWrapping="Wrap"
                                        Margin="40,2,40,2"/>

                                    <!-- Character / party-member bubble -->
                                    <Grid HorizontalAlignment="Left" MaxWidth="580"
                                          Visibility="{Binding IsCharacter, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="18"
                                                Background="#1E3A50" ClipToBounds="True"
                                                VerticalAlignment="Top" Margin="0,2,0,0">
                                            <Image Source="{Binding Portrait}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Grid.Column="2" Background="#111E2A"
                                                CornerRadius="0,12,12,12" Padding="12,8">
                                            <Border.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                           RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="✏ Edit" Click="EditMessage_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SenderName}"
                                                           Foreground="#C8A020" FontSize="10" FontWeight="Bold"
                                                           Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding Text}" Foreground="#D4C5A0"
                                                           FontSize="13" TextWrapping="Wrap"
                                                           Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Text="{Binding EditDraft, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#0A1820" BorderBrush="#1E4A60" BorderThickness="1"
                                                         Foreground="#D4C5A0" FontSize="13" TextWrapping="Wrap"
                                                         CaretBrush="#C8A020" AcceptsReturn="True" MinLines="2"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                            Margin="0,4,0,0"
                                                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                                    <Button Content="Save" Height="24" Padding="12,0" Margin="0,0,6,0"
                                                            FontSize="11" Background="#1A5A2A" Foreground="White"
                                                            BorderThickness="0" Cursor="Hand"
                                                            Command="{Binding DataContext.EditCommitCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Cancel" Height="24" Padding="12,0"
                                                            FontSize="11" Background="#3A1A1A" Foreground="#AAA"
                                                            BorderThickness="0" Cursor="Hand"
                                                            Command="{Binding DataContext.EditCancelCommand,
                                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding TimeStr}" Foreground="#4A6070"
                                                           FontSize="9" HorizontalAlignment="Left" Margin="0,4,0,0"
                                                           Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVis}}"/>
                                                <!-- Audio synthesizing indicator -->
                                                <TextBlock Text="&#9834;  generating audio…"
                                                           Foreground="#4A8AB0" FontSize="9" FontStyle="Italic"
                                                           Margin="0,2,0,0"
                                                           Visibility="{Binding IsSynthesizing, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSynthesizing}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                 From="1.0" To="0.25" Duration="0:0:0.9"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                    <!-- Scene Roster: narrator-managed NPCs currently in the scene -->
                    <Border Grid.Column="1" Width="160"
                            Background="#080E14"
                            BorderBrush="#1E3A50" BorderThickness="1,0,0,0"
                            Visibility="{Binding HasSceneNpcs, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="#1E3A50" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="GM" Foreground="#7A6010"
                                               FontSize="8" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="IN SCENE" Foreground="#C8A020"
                                               FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CurrentSceneNpcs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,5">
                                                <Border.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                                          RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="Promote to NPC" Click="PromoteSceneNpc_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="24" Height="24" CornerRadius="12"
                                                            Background="#1A2830"
                                                            VerticalAlignment="Center" Margin="0,0,7,0">
                                                        <TextBlock Text="{Binding Name, Converter={StaticResource FirstLetter}}"
                                                                   Foreground="#60A8C0" FontSize="10" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#90B8C8" FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" MaxWidth="110"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Regenerate button (Row 2, visible when there are AI responses to redo) -->
                <Border Grid.Row="2" Background="#080E14"
                        BorderBrush="#1E3A50" BorderThickness="0,1,0,0"
                        Visibility="{Binding CanRegenerate, Converter={StaticResource BoolToVis}}"
                        Padding="0,4">
                    <Button Content="↺  Regenerate last response"
                            HorizontalAlignment="Center"
                            Command="{Binding RegenerateCommand}"
                            Height="26" Padding="16,0" FontSize="11"
                            Background="#1A2E10" Foreground="#8AC878"
                            BorderBrush="#2A5A18" BorderThickness="1"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}"
                                        Height="{TemplateBinding Height}">
                                    <TextBlock Text="{TemplateBinding Content}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="{TemplateBinding FontSize}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#253E18"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <!-- Status + token counter (Row 3) -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding StatusText, Mode=OneWay}"
                             Foreground="#4A6070" FontSize="11" Margin="16,4,8,2"
                             Background="Transparent" BorderThickness="0"
                             IsReadOnly="True" TextWrapping="Wrap"
                             MaxHeight="80" VerticalScrollBarVisibility="Auto"
                             Cursor="IBeam"
                             Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Column="1" Text="{Binding TokenUsageText}"
                               Foreground="#2A4858" FontSize="9" Margin="0,5,16,2"
                               VerticalAlignment="Top"
                               Visibility="{Binding HasTokenUsage, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Author's note panel (Row 4, toggleable) -->
                <Border Grid.Row="4" Background="#080E14"
                        BorderBrush="#8A60C8" BorderThickness="0,1,0,0"
                        Visibility="{Binding IsAuthorsNoteOpen, Converter={StaticResource BoolToVis}}"
                        Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Author's Note" Foreground="#8A60C8" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border Grid.Column="1" Background="#111E2A"
                                CornerRadius="4" BorderBrush="#1E3A50" BorderThickness="1">
                            <TextBox Text="{Binding AuthorsNote, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#D4C5A0" FontSize="12" Padding="8,5"
                                     CaretBrush="#C8A020" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Quick action buttons (Row 5) -->
                <Border Grid.Row="5" Background="#080E14"
                        BorderBrush="#1E3A50" BorderThickness="0,1,0,0"
                        Padding="10,5"
                        IsEnabled="{Binding HasActiveCharacter}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ATK" Foreground="#6A4A10" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <Button Style="{StaticResource QuickBtnAtk}" Content="STR"
                                Tag="[attack str]"  Click="QuickInsert_Click" Margin="0,0,0,0"
                                ToolTip="Insert [attack str]"/>
                        <Button Style="{StaticResource QuickBtnAtk}" Content="DEX"
                                Tag="[attack dex]"  Click="QuickInsert_Click"
                                ToolTip="Insert [attack dex]"/>
                        <Button Style="{StaticResource QuickBtnAtk}" Content="SMP"
                                Tag="[attack str simple]" Click="QuickInsert_Click"
                                ToolTip="Insert [attack str simple] — unarmed / improvised (1d4)"/>

                        <Rectangle Width="1" Fill="#1E3A50" Margin="8,2"/>

                        <TextBlock Text="CHK" Foreground="#1A4A6A" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <Button Style="{StaticResource QuickBtnChk}" Content="STR"
                                Tag="[check str]" Click="QuickInsert_Click" Margin="0,0,0,0"
                                ToolTip="Insert [check str]"/>
                        <Button Style="{StaticResource QuickBtnChk}" Content="DEX"
                                Tag="[check dex]" Click="QuickInsert_Click"
                                ToolTip="Insert [check dex]"/>
                        <Button Style="{StaticResource QuickBtnChk}" Content="CON"
                                Tag="[check con]" Click="QuickInsert_Click"
                                ToolTip="Insert [check con]"/>
                        <Button Style="{StaticResource QuickBtnChk}" Content="INT"
                                Tag="[check int]" Click="QuickInsert_Click"
                                ToolTip="Insert [check int]"/>
                        <Button Style="{StaticResource QuickBtnChk}" Content="WIS"
                                Tag="[check wis]" Click="QuickInsert_Click"
                                ToolTip="Insert [check wis]"/>
                        <Button Style="{StaticResource QuickBtnChk}" Content="CHA"
                                Tag="[check cha]" Click="QuickInsert_Click"
                                ToolTip="Insert [check cha]"/>
                    </StackPanel>
                </Border>

                <!-- Input bar (Row 6) -->
                <Border Grid.Row="6" Background="#0A1018"
                        BorderBrush="#1E3A50" BorderThickness="0,1,0,0">
                    <Grid Margin="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>  <!-- play-as portrait -->
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>   <!-- text input -->
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="44"/>  <!-- author's note toggle -->
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="44"/>  <!-- voice toggle -->
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="44"/>  <!-- send -->
                        </Grid.ColumnDefinitions>

                        <!-- Play-as button -->
                        <Button x:Name="PlayAsBtn" Grid.Column="0"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Click="PlayAsBtn_Click"
                                ToolTip="Play as character…">
                            <Border Width="36" Height="36" CornerRadius="18"
                                    Background="#1E3A50" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="{Binding PlayAsInitial}"
                                               Foreground="#C8A020" FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image Source="{Binding PlayAsPortrait}" Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- Text input -->
                        <Border Grid.Column="2" Background="#111E2A"
                                CornerRadius="4" BorderBrush="#1E3A50" BorderThickness="1">
                            <TextBox x:Name="InputBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#D4C5A0" FontSize="13" Padding="10,7"
                                     CaretBrush="#C8A020"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     MinLines="2" MaxLines="3"
                                     VerticalScrollBarVisibility="Auto"
                                     IsEnabled="{Binding HasActiveCharacter}"
                                     PreviewKeyDown="InputBox_PreviewKeyDown"
                                     KeyDown="InputBox_KeyDown"/>
                        </Border>

                        <!-- Author's note toggle -->
                        <ToggleButton Grid.Column="4" Content="✍"
                                      Style="{StaticResource VoiceToggleBtn}"
                                      IsChecked="{Binding IsAuthorsNoteOpen}"
                                      ToolTip="Author's note"/>

                        <ToggleButton Grid.Column="6" Content="🔊"
                                      Style="{StaticResource VoiceToggleBtn}"
                                      IsChecked="{Binding IsVoiceEnabled}"
                                      ToolTip="Toggle voice"/>
                        <Button Grid.Column="8" Content="▶"
                                Style="{StaticResource ActionBtn}"
                                Command="{Binding SendCommand}"
                                ToolTip="Send (Enter)"/>
                    </Grid>
                </Border>

                <!-- Play-as picker popup -->
                <Popup x:Name="PlayAsPopup"
                       PlacementTarget="{Binding ElementName=PlayAsBtn}"
                       Placement="Top" StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="#0A1018" BorderBrush="#C8A020" BorderThickness="1"
                            MinWidth="200" MaxHeight="320" Effect="{x:Null}">
                        <StackPanel>
                            <!-- "Player" default option -->
                            <Button Click="PlayAsPlayer_Click" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Left">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="10,8">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        Background="#1E3A50" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding PlayAsInitial}"
                                                               Foreground="#C8A020" FontSize="11" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding PlayAsName}"
                                                               Foreground="#D4C5A0" FontSize="12"/>
                                                    <TextBlock Text="(default)" Foreground="#4A6070" FontSize="9"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Border Height="1" Background="#1E3A50" Margin="8,0"/>

                            <!-- Character list -->
                            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AllCharactersFlat}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Tag="{Binding}" Click="PlayAsCharacter_Click"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                Padding="10,6">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="28" Height="28" CornerRadius="14"
                                                                        Background="#1E3A50" ClipToBounds="True"
                                                                        VerticalAlignment="Center" Margin="0,0,8,0">
                                                                    <Image Source="{Binding Portrait}" Stretch="UniformToFill"/>
                                                                </Border>
                                                                <StackPanel VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Foreground="#D4C5A0" FontSize="12"/>
                                                                    <TextBlock Text="{Binding CategoryBadge}"
                                                                               Foreground="#4A6070" FontSize="9"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#111E2A"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </Grid>
</Window>
