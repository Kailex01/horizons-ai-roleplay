<Window x:Class="GukVoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GukVoice.ViewModels"
        Title="GukVoice" Height="640" Width="960" MinWidth="720" MinHeight="420"
        Background="{StaticResource BgBrush}"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- Flat colored square used as a color-picker swatch button -->
        <Style x:Key="ColorSwatch" TargetType="Button">
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="6,0,0,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="ToolTip"         Value="Click to change color"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── Main content ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ──────────────────────────────────────────────── -->
            <Grid Grid.Column="0" Background="{StaticResource SurfaceBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="10,8">
                    <TextBlock Text="SPEAKERS" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource SubtextBrush}"/>
                </Border>

                <!-- Speaker list -->
                <ListBox Grid.Row="1" x:Name="SpeakerListBox"
                         ItemsSource="{Binding Speakers}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background"   Value="Transparent"/>
                            <Setter Property="Padding"      Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2E2E48"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2E2E48"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SpeakerItem}">
                            <Grid Margin="10,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Status dot -->
                                <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource IdleBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasPending}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource PendingBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource ActiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <!-- Name + type -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding Type}" Foreground="{StaticResource SubtextBrush}"
                                               FontSize="10"/>
                                </StackPanel>

                                <!-- Speaking label -->
                                <TextBlock Grid.Column="2" Text="speaking" FontSize="9"
                                           Foreground="{StaticResource ActiveBrush}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <DataTemplate.Triggers>
                                <!-- Right-click context menu on the row -->
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Edit…"
                                      Command="{Binding PlacementTarget.DataContext.EditSpeakerCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="Remove"
                                      Command="{Binding PlacementTarget.DataContext.RemoveSpeakerCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                         RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <!-- Add button -->
                <Button Grid.Row="2" Content="＋  Add Speaker"
                        Command="{Binding AddSpeakerCommand}"
                        Style="{StaticResource DarkButton}"
                        Margin="10" HorizontalAlignment="Stretch"/>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

            <!-- ── Right panel ───────────────────────────────────────────── -->
            <TabControl Grid.Column="2" Background="{StaticResource BgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">

                <!-- ── Activity Feed tab ─────────────────────────────────── -->
                <TabItem Header="Activity">
                    <ListBox ItemsSource="{Binding ActivityFeed}"
                             Background="Transparent" BorderThickness="0"
                             VirtualizingPanel.IsVirtualizing="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Consolas" FontSize="12">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"           Value="0"/>
                                <Setter Property="Background"        Value="Transparent"/>
                                <Setter Property="BorderThickness"   Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ActivityItem}">
                                <Grid Margin="6,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Tag pill -->
                                    <Border Grid.Column="0" Background="{Binding TagBackground}"
                                            CornerRadius="3" Padding="5,1" Margin="0,0,8,0"
                                            VerticalAlignment="Center" MinWidth="55">
                                        <TextBlock Text="{Binding Tag}"
                                                   Foreground="{Binding TagForeground}"
                                                   FontWeight="Bold" FontSize="10"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Timestamp -->
                                    <TextBlock Grid.Column="1" Text="{Binding Time}"
                                               Foreground="{StaticResource SubtextBrush}"
                                               FontSize="10" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                    <!-- Message -->
                                    <TextBlock Grid.Column="2" Text="{Binding Text}"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>

                <!-- ── Overlay (FCT) tab ────────────────────────────────── -->
                <TabItem Header="Overlay">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,16">

                            <!-- Master enable -->
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,10" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding Fct.Enabled}"
                                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Enable Floating Combat Text"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="Overlay numbers animate above the EQ window center"
                                                   Foreground="{StaticResource SubtextBrush}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ORIGIN section -->
                            <TextBlock Text="ORIGIN" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,10" Margin="0,0,0,14">
                                <StackPanel>
                                    <!-- EQ window size info (populated when EQ is running) -->
                                    <TextBlock Text="{Binding EqWindowDiag}"
                                               Foreground="{StaticResource SubtextBrush}"
                                               FontSize="11" Margin="0,0,0,10"
                                               FontFamily="Consolas"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4">
                                        <TextBlock Text="X Offset" Width="58"
                                                   Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Fct.OriginOffsetX, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="52" FontSize="12" Padding="4,3"
                                                 Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        <TextBlock Text="Y Offset" Width="58"
                                                   Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                                   VerticalAlignment="Center" Margin="14,0,0,0"/>
                                        <TextBox Text="{Binding Fct.OriginOffsetY, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="52" FontSize="12" Padding="4,3"
                                                 Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        <TextBlock Text="pixels from window center  (+right / +down)"
                                                   Foreground="{StaticResource SubtextBrush}" FontSize="10"
                                                   VerticalAlignment="Center" Margin="14,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <TextBlock Text="Font" Width="58"
                                                   Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox IsEditable="True"
                                                  ItemsSource="{Binding Fct.SystemFontNames}"
                                                  Text="{Binding Fct.FontFamily, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="180" MaxDropDownHeight="220" FontSize="12"
                                                  Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                  BorderBrush="{StaticResource BorderBrush}"
                                                  ToolTip="Pick from list or type any installed font name"/>
                                        <CheckBox IsChecked="{Binding Fct.GlobalBold}"
                                                  VerticalAlignment="Center" Margin="14,0,4,0"/>
                                        <TextBlock Text="Bold" FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding Fct.GlobalItalic}"
                                                  VerticalAlignment="Center" Margin="12,0,4,0"/>
                                        <TextBlock Text="Italic" FontStyle="Italic" FontSize="12"
                                                   Foreground="{StaticResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <TextBlock Text="Spread" Width="58"
                                                   Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Text="{Binding Fct.AngleSpread, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="40" FontSize="12" Padding="4,3"
                                                 Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                 ToolTip="Max angle variance in degrees (0 = no spread)"/>
                                        <TextBlock Text="°  angle variance"
                                                   Foreground="{StaticResource SubtextBrush}" FontSize="10"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8">
                                        <CheckBox IsChecked="{Binding Fct.ShowDebugOrigin}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel>
                                            <TextBlock Text="Show origin marker"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="Red crosshair at the spawn point — turn off before playing"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- GROUP MEMBERS section -->
                            <TextBlock Text="GROUP MEMBERS" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,10" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Select whose FCT events to display — one at a time"
                                               Foreground="{StaticResource SubtextBrush}" FontSize="11"
                                               Margin="0,0,0,10"/>
                                    <!-- Self (default) -->
                                    <RadioButton GroupName="FCTSubject"
                                                 IsChecked="{Binding Fct.IsSelf}"
                                                 Foreground="{StaticResource TextBrush}"
                                                 FontSize="13" Margin="0,3">
                                        <TextBlock Text="Self (your events)" Foreground="{StaticResource TextBrush}"/>
                                    </RadioButton>
                                    <!-- One radio per configured group member -->
                                    <ItemsControl ItemsSource="{Binding Fct.GroupMemberOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                                    <RadioButton GroupName="FCTSubject"
                                                                 IsChecked="{Binding IsActive}"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontSize="13" Width="150"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="×" FontSize="14" FontWeight="Bold"
                                                            Tag="{Binding Name}"
                                                            Click="OnRemoveGroupMember"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="{StaticResource SubtextBrush}"
                                                            Cursor="Hand" Padding="4,0"
                                                            VerticalAlignment="Center" ToolTip="Remove"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Add member -->
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBox x:Name="NewMemberNameBox"
                                                 Width="160" FontSize="12" Padding="4,3"
                                                 Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                 ToolTip="Character name to add as an option"/>
                                        <Button Content="Add" Margin="8,0,0,0" Padding="10,3"
                                                Click="OnAddGroupMember" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- DAMAGE section -->
                            <TextBlock Text="DAMAGE" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,8" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowDamageOut}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Damage Out  (melee)"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="hits you deal with melee attacks"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeDamageOut, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="DamageOut" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushDamageOut}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="DamageOut|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushDamageOut}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowDamageIn}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Damage In  (melee)"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="melee hits you take"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeDamageIn, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="DamageIn" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushDamageIn}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="DamageIn|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushDamageIn}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowCritOut}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Crit Out"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="critical hits and crippling blows you land"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeCritOut, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="CritOut" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushCritOut}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="CritOut|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushCritOut}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowCritIn}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Crit In"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="critical hits you take"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeCritIn, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="CritIn" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushCritIn}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="CritIn|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushCritIn}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- SPELLS section -->
                            <TextBlock Text="SPELLS" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,8" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowSpellOut}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Spell Damage Out"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="non-melee damage you deal"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeSpellOut, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="SpellOut" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushSpellOut}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="SpellOut|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushSpellOut}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowSpellIn}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Spell Damage In"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="non-melee damage you take"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeSpellIn, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="SpellIn" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushSpellIn}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="SpellIn|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushSpellIn}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- HEALING section -->
                            <TextBlock Text="HEALING" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,8" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowHealFriendly}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Healing — Friendly"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="heals you give or receive"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeHealFriendly, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="HealFriendly" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushHealFriendly}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="HealFriendly|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushHealFriendly}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowHealEnemy}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Healing — Enemy"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="heals enemies receive"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeHealEnemy, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="HealEnemy" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushHealEnemy}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="HealEnemy|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushHealEnemy}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- OTHER section -->
                            <TextBlock Text="OTHER" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="14,8" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowLevelUp}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Level Up"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="DING! with your new level — arcs up and falls"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeLevelUp, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="LevelUp" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushLevelUp}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="LevelUp|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushLevelUp}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowExpGain}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Experience Gain"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="fires on every kill, off by default"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeExpGain, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="ExpGain" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushExpGain}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="ExpGain|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushExpGain}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowStunned}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Stunned"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="shows STUNNED when you are stunned"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeStunned, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="Stunned" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushStunned}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="Stunned|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushStunned}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Fct.ShowFeared}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Feared"
                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                            <TextBlock Text="shows FEARED, slowly floats upward"
                                                       Foreground="{StaticResource SubtextBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Margin="12,0,0,0">
                                            <TextBlock Text="Size" Foreground="{StaticResource SubtextBrush}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox Text="{Binding Fct.FontSizeFeared, StringFormat=0, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="42" FontSize="12" Padding="4,3"
                                                     Background="#1E1E2E" Foreground="{StaticResource TextBrush}"
                                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Tag="Feared" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.BrushFeared}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Fill color"/>
                                        <Button Grid.Column="4" Tag="Feared|Stroke" Click="OnColorSwatchClick"
                                                Background="{Binding Fct.StrokeBrushFeared}"
                                                Style="{StaticResource ColorSwatch}" VerticalAlignment="Center"
                                                ToolTip="Outline color"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ── Combat tab ────────────────────────────────────────── -->
                <TabItem Header="Combat">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Current fight stats panel -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="16,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Status + target -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource IdleBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Combat.InCombat}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Combat.StatusText}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Combat.TargetText}"
                                               Foreground="{StaticResource SubtextBrush}"
                                               FontSize="14" Margin="12,0,0,0"/>
                                </StackPanel>

                                <!-- Stat grid -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="DURATION" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding Combat.DurationText}"
                                                   Foreground="{StaticResource TextBrush}" FontSize="15"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="DAMAGE DEALT" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding Combat.DmgDealtText}"
                                                   Foreground="#B5CEA8" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="DAMAGE TAKEN" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock Text="{Binding Combat.DmgTakenText}"
                                                   Foreground="#CE8888" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="DPS OUT / IN" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Combat.DpsOutText}"
                                                       Foreground="#B5CEA8" FontSize="15" FontWeight="Bold"/>
                                            <TextBlock Text=" / " Foreground="{StaticResource SubtextBrush}" FontSize="15"/>
                                            <TextBlock Text="{Binding Combat.DpsInText}"
                                                       Foreground="#CE8888" FontSize="15" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Fight history -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="16,8,16,4">
                                <TextBlock Text="FIGHT HISTORY"
                                           Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right"
                                        Command="{Binding Combat.ClearCommand}"
                                        Style="{StaticResource DarkButton}"
                                        Padding="8,2" FontSize="11"
                                        Content="Clear"/>
                            </Grid>
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Combat.FightHistory}"
                                     Background="Transparent" BorderThickness="0"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     FontFamily="Consolas" FontSize="12">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"         Value="16,5"/>
                                        <Setter Property="Background"      Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#24243A"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FightRecord}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="3" Padding="4,1"
                                                    Margin="0,0,10,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#CE8888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Won}" Value="True">
                                                                <Setter Property="Background" Value="#44AA66"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Result}" FontSize="9"
                                                           FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Summary}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Start / Pause toggle -->
                <Button Grid.Column="0"
                        Command="{Binding ToggleMonitoringCommand}"
                        BorderThickness="0" Background="Transparent"
                        Padding="10,0" Cursor="Hand" VerticalAlignment="Stretch"
                        ToolTip="Start or pause log monitoring">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                            <Setter Property="Content"     Value="⏸ Pause"/>
                            <Setter Property="Foreground"  Value="{StaticResource ActiveBrush}"/>
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWatching}" Value="False">
                                    <Setter Property="Content"    Value="▶ Start"/>
                                    <Setter Property="Foreground" Value="{StaticResource PendingBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center" Margin="4,0"
                           FontSize="11"/>

                <!-- Archive Log -->
                <Button Grid.Column="2"
                        Command="{Binding ArchiveLogCommand}"
                        BorderThickness="0" Background="Transparent"
                        Padding="10,0" Cursor="Hand" VerticalAlignment="Stretch"
                        ToolTip="Archive log and wait for EQ to create a new one"
                        Style="{StaticResource DarkButton}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="🗄" FontSize="13"
                                       Foreground="{StaticResource SubtextBrush}"/>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <!-- Reload TTS -->
                <Button Grid.Column="3"
                        Command="{Binding ReloadTtsCommand}"
                        BorderThickness="0" Background="Transparent"
                        Padding="10,0" Cursor="Hand" VerticalAlignment="Stretch"
                        ToolTip="Reload TTS model and rebuild voice blends"
                        Style="{StaticResource DarkButton}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="↺" FontSize="14"
                                       Foreground="{StaticResource SubtextBrush}"/>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <!-- Settings -->
                <Button Grid.Column="4"
                        Command="{Binding OpenSettingsCommand}"
                        BorderThickness="0" Background="Transparent"
                        Padding="10,0" Cursor="Hand" VerticalAlignment="Stretch"
                        ToolTip="Settings"
                        Style="{StaticResource DarkButton}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="⚙" FontSize="13"
                                       Foreground="{StaticResource SubtextBrush}"/>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
